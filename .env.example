DB_HOST=db
DB_PORT=3306
DB_NAME=webapp
DB_USER=webuser
DB_PASS=geheimespasswort

# E-Mail-Konfiguration
# MAIL_FROM: Absenderadresse (z.B. noreply@ihre-schule.de)
MAIL_FROM=noreply@example.com

# SMTP-Zugangsdaten
# SMTP_HOST: Hostname des Mailservers (z.B. mail.ihre-schule.de oder smtp.gmail.com)
SMTP_HOST=mail.example.com
# SMTP_PORT: 587 für TLS/STARTTLS, 465 für SSL, 25 für unverschlüsselt
SMTP_PORT=587
# SMTP_SECURE: tls, ssl oder leer lassen für keine Verschlüsselung
SMTP_SECURE=tls
# SMTP_USER: Benutzername / E-Mail-Adresse des Absenderkontos
SMTP_USER=noreply@example.com
# SMTP_PASS: Passwort des Absenderkontos
SMTP_PASS=ihr-smtp-passwort

APP_ENV=production
